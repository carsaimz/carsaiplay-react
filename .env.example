# ─── Frontend (Vite) ──────────────────────────────────────────────────
VITE_API_URL=https://carsaiplay.vercel.app/api/v1
VITE_APP_NAME=CarsaiPlay
VITE_APP_VERSION=2.1.0

# ─── Firebase ─────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=AIza...
