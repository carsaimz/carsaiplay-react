# Segredo para hash de passwords
APP_SECRET=muda_este_segredo_para_algo_muito_seguro_e_aleatorio

# URL pública da aplicação
APP_URL=https://carsaiplay.vercel.app

# Firebase (backend — verificação de tokens)
FIREBASE_PROJECT_ID=carsaiplay
FIREBASE_API_KEY=AIza...
